## 6. Crearea tabelelor in SQL si inserarea datelor

### 6.1 Crearea tabelelor

```sql
-- Tabele independente
CREATE TABLE COMPLEX_SPORTIV (
    complex_id NUMBER(10) PRIMARY KEY,
    nume_complex VARCHAR2(100) NOT NULL,
    adresa VARCHAR2(255) NOT NULL,
    program_functionare VARCHAR2(50)
);

CREATE TABLE CLIENT (
    client_id NUMBER(10) PRIMARY KEY,
    nume VARCHAR2(50) NOT NULL,
    prenume VARCHAR2(50) NOT NULL,
    email VARCHAR2(100) NOT NULL UNIQUE,
    telefon VARCHAR2(15),
    data_inregistrare DATE DEFAULT SYSDATE
);

CREATE TABLE ABONAMENT (
    abonament_id NUMBER(10) PRIMARY KEY,
    tip_abonament VARCHAR2(50) NOT NULL,
    data_inceput DATE NOT NULL,
    data_expirare DATE NOT NULL,
    pret NUMBER(8, 2) NOT NULL,
    client_id NUMBER(10) NOT NULL UNIQUE,
    CONSTRAINT fk_abonament_client FOREIGN KEY (client_id) REFERENCES CLIENT(client_id)
);

CREATE TABLE ECHIPAMENT (
    echipament_id NUMBER(10) PRIMARY KEY,
    nume_echipament VARCHAR2(100) NOT NULL,
    pret_inchiriere_ora NUMBER(6, 2) NOT NULL
);

CREATE TABLE TEREN (
    teren_id NUMBER(10) PRIMARY KEY,
    pret_ora NUMBER(6, 2) NOT NULL,
    capacitate_maxima NUMBER(3),
    tip_teren VARCHAR2(20) NOT NULL,
    complex_id NUMBER(10) NOT NULL,
    CONSTRAINT fk_teren_complex FOREIGN KEY (complex_id) REFERENCES COMPLEX_SPORTIV(complex_id),
    CONSTRAINT chk_tip_teren CHECK (tip_teren IN ('Tenis', 'Fotbal', 'Piscina'))
);

-- Subtabele (Specializări)
CREATE TABLE TEREN_TENIS (
    teren_id NUMBER(10) PRIMARY KEY,
    tip_suprafata VARCHAR2(20) NOT NULL,
    CONSTRAINT fk_tenis_teren FOREIGN KEY (teren_id) REFERENCES TEREN(teren_id),
    CONSTRAINT chk_suprafata_tenis CHECK (tip_suprafata IN ('Zgura', 'Hard', 'Iarba'))
);

CREATE TABLE TEREN_FOTBAL (
    teren_id NUMBER(10) PRIMARY KEY,
    tip_gazon VARCHAR2(20) NOT NULL,
    este_acoperit NUMBER(1) DEFAULT 0 NOT NULL,
    CONSTRAINT fk_fotbal_teren FOREIGN KEY (teren_id) REFERENCES TEREN(teren_id),
    CONSTRAINT chk_gazon_fotbal CHECK (tip_gazon IN ('Natural', 'Sintetic')),
    CONSTRAINT chk_acoperit_fotbal CHECK (este_acoperit IN (0, 1))
);

CREATE TABLE PISCINA (
    teren_id NUMBER(10) PRIMARY KEY,
    adancime_metri NUMBER(4, 2) NOT NULL,
    este_acoperita NUMBER(1) DEFAULT 0 NOT NULL,
    CONSTRAINT fk_piscina_teren FOREIGN KEY (teren_id) REFERENCES TEREN(teren_id),
    CONSTRAINT chk_acoperita_piscina CHECK (este_acoperita IN (0, 1))
);

CREATE TABLE VESTIAR (
    complex_id NUMBER(10),
    nr_vestiar NUMBER(3),
    gen VARCHAR2(10) NOT NULL,
    capacitate NUMBER(3) NOT NULL,
    PRIMARY KEY (complex_id, nr_vestiar),
    CONSTRAINT fk_vestiar_complex FOREIGN KEY (complex_id) REFERENCES COMPLEX_SPORTIV(complex_id),
    CONSTRAINT chk_gen_vestiar CHECK (gen IN ('Masculin', 'Feminin', 'Mixt'))
);

CREATE TABLE REZERVARE (
    rezervare_id NUMBER(10) PRIMARY KEY,
    data_rezervare DATE NOT NULL,
    ora_inceput TIMESTAMP NOT NULL,
    ora_sfarsit TIMESTAMP NOT NULL,
    status_plata VARCHAR2(20) DEFAULT 'Neplatit' NOT NULL,
    client_id NUMBER(10) NOT NULL,
    teren_id NUMBER(10) NOT NULL,
    CONSTRAINT fk_rezervare_client FOREIGN KEY (client_id) REFERENCES CLIENT(client_id),
    CONSTRAINT fk_rezervare_teren FOREIGN KEY (teren_id) REFERENCES TEREN(teren_id),
    CONSTRAINT chk_status_plata CHECK (status_plata IN ('Platit', 'Neplatit', 'Anulat'))
);

-- Tabele asociative
CREATE TABLE PARTICIPANTI_REZERVARE (
    client_id NUMBER(10),
    rezervare_id NUMBER(10),
    PRIMARY KEY (client_id, rezervare_id),
    CONSTRAINT fk_part_client FOREIGN KEY (client_id) REFERENCES CLIENT(client_id),
    CONSTRAINT fk_part_rezervare FOREIGN KEY (rezervare_id) REFERENCES REZERVARE(rezervare_id)
);

CREATE TABLE INCHIRIERE (
    client_id NUMBER(10),
    rezervare_id NUMBER(10),
    echipament_id NUMBER(10),
    cantitate NUMBER(3) DEFAULT 1 NOT NULL,
    PRIMARY KEY (client_id, rezervare_id, echipament_id),
    CONSTRAINT fk_inc_client FOREIGN KEY (client_id) REFERENCES CLIENT(client_id),
    CONSTRAINT fk_inc_rezervare FOREIGN KEY (rezervare_id) REFERENCES REZERVARE(rezervare_id),
    CONSTRAINT fk_inc_echipament FOREIGN KEY (echipament_id) REFERENCES ECHIPAMENT(echipament_id)
);
```

